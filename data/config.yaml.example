# UAV Configuration Settings

# Operation Mode (PX4 or Ardupilot)
# This value is authoritative: it is read once at startup and all
# mode-derived constants (STATUS_ORDER, PARAM, PARAM_PART, paths) are
# computed from it. Override per-run via the ICSEARCHER_MODE env var
# (config is frozen at load time — there is no runtime select_mode).
mode: Ardupilot

# Simulation Settings
simulation:
  speed: 3
  home: AVC_plane
  debug: true
  wind_range: [8, 10.7]
  window:
    width: 640
    height: 480
  altitude:
    limit_high: 50
    limit_low: 40

# Path Settings
# Leave a path empty ("") to fall back to the per-mode default. Absolute
# paths are used as-is; relative paths are resolved against the repo root.
paths:
  ardupilot_log: /media/rain/data
  sitl: /home/rain/ardupilot/Tools/autotest/sim_vehicle.py
  airsim: /media/rain/data/airsim/Africa_Savannah/LinuxNoEditor/Africa_001.sh
  px4_run: /home/rain/PX4-Autopilot
  jmavsim: /home/rain/PX4-Autopilot/Tools/jmavsim_run.sh
  morse: /home/rain/ardupilot/libraries/SITL/examples/Morse/quadcopter.py

# Model Settings
model:
  type: lstm           # lstm | tcn — 选哪个代理模型;覆盖用 ICSEARCHER_MODEL_TYPE
  input_len: 4
  output_len: 1
  segment_len: 14
  retrans: true

cluster_choice_num: 10

# Parallel multi-instance SITL. ``instances`` is the number of simulator
# processes that run concurrently during collect / validate (each gets its own
# UDP port 14540+i and its own working directory). Default 1 preserves the
# historical single-instance behaviour. Override per-run with the
# ICSEARCHER_INSTANCES env var or the --instances flag.
parallel:
  instances: 1
  instance_dir: instance_{i}   # per-instance working subdir; {i} = instance index

# Parameter Files (relative to repo root by default)
param_files:
  ardupilot: data/param_ardu.json
  px4: data/param_px4.json

# Mission files (relative to repo root; defaults to data/fitCollection[_px4].txt)
missions:
  fit_collection:
    ardupilot: data/fitCollection.txt
    px4: data/fitCollection_px4.txt
